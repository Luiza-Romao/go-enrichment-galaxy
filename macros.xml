<macros>

    <token name="@TOOL_VERSION@">1.0</token>
    <token name="@VERSION_SUFFIX@">+galaxy0</token>

    <xml name="requirements">
        <requirements>
            <!-- R base — must match Bioconductor 3.20 -->
            <requirement type="package" version="4.4">r-base</requirement>

            <!-- GO enrichment — Bioconductor 3.20 -->
            <requirement type="package" version="4.14.0">bioconductor-clusterprofiler</requirement>
            <requirement type="package" version="1.26.0">bioconductor-enrichplot</requirement>
            <requirement type="package" version="3.32.0">bioconductor-dose</requirement>
            <requirement type="package" version="1.68.0">bioconductor-annotationdbi</requirement>

            <!-- OrgDb packages — Bioconductor 3.20 -->
            <!-- Add or remove according to the organisms you need -->
            <requirement type="package" version="3.20.0">bioconductor-org.at.tair.db</requirement>
            <requirement type="package" version="3.20.0">bioconductor-org.hs.eg.db</requirement>
            <requirement type="package" version="3.20.0">bioconductor-org.mm.eg.db</requirement>
            <requirement type="package" version="3.20.0">bioconductor-org.sc.sgd.db</requirement>
            <requirement type="package" version="3.20.0">bioconductor-org.os.eg.db</requirement>

            <!-- CRAN packages -->
            <requirement type="package" version="3.5.1">r-ggplot2</requirement>
            <requirement type="package" version="0.9.6">r-ggrepel</requirement>
            <requirement type="package" version="1.7.5">r-optparse</requirement>
        </requirements>
    </xml>

    <xml name="orgdb_param">
        <param name="orgdb" type="select"
            label="Reference organism database (OrgDb)"
            help="The organism whose GO annotation will be used for enrichment.
                  For sugarcane transcripts, choose Arabidopsis thaliana and provide an ID mapping file below.">
            <option value="org.At.tair.db" selected="true">Arabidopsis thaliana (org.At.tair.db)</option>
            <option value="org.Hs.eg.db">Homo sapiens (org.Hs.eg.db)</option>
            <option value="org.Mm.eg.db">Mus musculus (org.Mm.eg.db)</option>
            <option value="org.Os.eg.db">Oryza sativa (org.Os.eg.db)</option>
            <option value="org.Sc.sgd.db">Saccharomyces cerevisiae (org.Sc.sgd.db)</option>
        </param>
    </xml>

    <xml name="keytype_param">
        <param name="keytype" type="select"
            label="Gene ID type in the (mapped) gene list"
            help="Must match the ID format expected by the selected OrgDb.
                  For Arabidopsis: use TAIR (e.g. AT1G01010).
                  For Human/Mouse: use ENTREZID or SYMBOL.">
            <option value="TAIR" selected="true">TAIR (Arabidopsis — e.g. AT1G01010)</option>
            <option value="ENTREZID">ENTREZID (numeric Entrez Gene ID)</option>
            <option value="SYMBOL">SYMBOL (gene symbol)</option>
            <option value="ENSEMBL">ENSEMBL (e.g. ENSG00000000003)</option>
            <option value="UNIPROT">UNIPROT (UniProt accession)</option>
        </param>
    </xml>

    <xml name="enrichment_thresholds">
        <section name="thresholds" title="Enrichment thresholds" expanded="false">
            <param name="pvalue_cutoff" type="float" value="0.05" min="0.001" max="0.2"
                label="Adjusted p-value cutoff"
                help="GO terms with BH-adjusted p-value above this threshold are discarded. Default: 0.05" />
            <param name="qvalue_cutoff" type="float" value="0.2" min="0.001" max="0.5"
                label="q-value cutoff"
                help="Additional FDR control via q-value. Default: 0.2" />
            <param name="min_gs_size" type="integer" value="10" min="3" max="100"
                label="Minimum gene-set size"
                help="GO terms annotating fewer than this many genes are excluded. Default: 10" />
            <param name="max_gs_size" type="integer" value="500" min="50" max="5000"
                label="Maximum gene-set size"
                help="GO terms annotating more than this many genes are excluded. Default: 500" />
            <param name="top_terms" type="integer" value="15" min="5" max="50"
                label="Top terms per module in plots"
                help="Number of most significant GO terms to display per module. Default: 15" />
        </section>
    </xml>

    <xml name="citations">
        <citations>
            <citation type="doi">10.1093/nar/gkac995</citation>
            <citation type="doi">10.1089/omi.2011.0118</citation>
        </citations>
    </xml>

</macros>
